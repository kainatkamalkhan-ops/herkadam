# Copy this file to ".env.local" and paste your project values.
# Supabase → Project Settings → API: Project URL + anon public key

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — Supabase → Project Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Admin pages (/admin/*) — choose a strong password
ADMIN_PASSWORD=

# Welcome emails (quiz + newsletter) — https://resend.com
# Verify your domain in Resend, then use e.g. Her Kadam <hello@herkadam.com>
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Contact form inbox (defaults to herkadamofficial@gmail.com)
CONTACT_INBOX_EMAIL=herkadamofficial@gmail.com

# Optional — run scripts/run-quiz-migration.mjs without SQL Editor
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# SUPABASE_ACCESS_TOKEN=

# Optional — only if your table name is not "opportunities"
# NEXT_PUBLIC_SUPABASE_OPPORTUNITIES_TABLE=opportunities
