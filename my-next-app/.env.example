# Copy this file to ".env.local" and paste your project values.
# Supabase → Project Settings → API: Project URL + anon public key

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — Supabase → Project Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Admin pages (/admin/*) — choose a strong password
ADMIN_PASSWORD=

# Optional — only if your table name is not "opportunities"
# NEXT_PUBLIC_SUPABASE_OPPORTUNITIES_TABLE=opportunities
